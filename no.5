<!doctype html>
<html>
  <head>
    <title>Task Progress Table</title>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <table>
      <thead>
        <tr>
          <th colspan="3" class="main-heading">Task Progress</th>
        </tr>
        <tr>
          <th>Task</th>
          <th>Status</th>
          <th>Deadline</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Design Mockup</td>
          <td><span class="completed">Completed</span></td>
          <td>August 15</td>
        </tr>
        <tr class="alt-row">
          <td>Write Documentation</td>
          <td><span class="inprogress">In Progress</span></td>
          <td>August 20</td>
        </tr>
        <tr>
          <td>Testing Phase</td>
          <td><span class="pending">Pending</span></td>
          <td>August 25</td>
        </tr>
      </tbody>
    </table>
  </body>
</html>
