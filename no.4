<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: sans-serif; text-align: center; }
        table { 
            width: 80%; 
            margin: auto; 
            border-collapse: collapse; 
        }
        th, td { 
            border: 1px solid #ccc; 
            padding: 10px; 
        }
        th { background-color: #f2f2f2; }
        h1 { font-family: serif; }
    </style>
</head>
<body>

    <h1>My Schedule</h1>

    <table>
        <tr>
            <th>Day</th>
            <th>Task</th>
            <th>Time</th>
        </tr>
        <tr>
            <td>Monday</td>
            <td>Code Practice</td>
            <td>10:00 AM</td>
        </tr>
        <tr>
            <td>Wednesday</td>
            <td>Team Meeting</td>
            <td>2:00 PM</td>
        </tr>
        <tr>
            <td>Friday</td>
            <td>Project Review</td>
            <td>4:00 PM</td>
        </tr>
    </table>

</body>
</html>
