CREATE TABLE Department (
    Dept_ID INT PRIMARY KEY,
    Dept_Name VARCHAR(50) NOT NULL
);
---------------------------------------------------------------------------------------------------------------------------------
CREATE TABLE Student (
    Student_ID INT PRIMARY KEY,
    Student_Name VARCHAR(100) NOT NULL,
    Email VARCHAR(100) UNIQUE NOT NULL,
    Age INT CHECK (Age > 0),
    Dept_ID INT,
    FOREIGN KEY (Dept_ID) REFERENCES Department(Dept_ID) ON DELETE SET NULL
);
---------------------------------------------------------------------------------------------------------------------------------

CREATE TABLE Course (
    Course_ID INT PRIMARY KEY,
    Course_Name VARCHAR(100) NOT NULL,
    Credits INT NOT NULL CHECK (Credits > 0),
    Dept_ID INT,
    FOREIGN KEY (Dept_ID) REFERENCES Department(Dept_ID) ON DELETE SET NULL
);
---------------------------------------------------------------------------------------------------------------------------------

CREATE TABLE Enrollments (
    Enrollment_ID INT PRIMARY KEY,
    Student_ID INT,
    Course_Name VARCHAR(100) NOT NULL,
    Semester VARCHAR(20) NOT NULL,
    FOREIGN KEY (Student_ID) REFERENCES Student(Student_ID) ON DELETE CASCADE
);
---------------------------------------------------------------------------------------------------------------------------------

CREATE VIEW View_Student_Details AS
SELECT Student_Name, Email, Dept_ID
FROM Student;
---------------------------------------------------------------------------------------------------------------------------------

CREATE VIEW View_Adult_Students AS
SELECT Student_ID, Student_Name, Email, Age, Dept_ID
FROM Student
WHERE Age > 20;
---------------------------------------------------------------------------------------------------------------------------------

CREATE VIEW View_Course_Credits AS
SELECT Course_Name, Credits
FROM Course;
---------------------------------------------------------------------------------------------------------------------------------

SELECT * FROM View_Student_Details;
