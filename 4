SELECT Department, COUNT(DISTINCT stud_id) AS Total_Students
FROM Student_Result
GROUP BY Department;
-------------------------------------------------------------------------------------------------------------------------------
SELECT subject, AVG(Marks) AS Average_Marks
FROM Student_Result
GROUP BY subject;
-------------------------------------------------------------------------------------------------------------------------------
SELECT Department, AVG(Marks) AS Average_Marks
FROM Student_Result
GROUP BY Department
HAVING AVG(Marks) > 80;
-------------------------------------------------------------------------------------------------------------------------------

SELECT subject, COUNT(DISTINCT stud_id) AS Student_Count
FROM Student_Result
GROUP BY subject
HAVING COUNT(DISTINCT stud_id) > 2;
