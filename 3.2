SELECT DISTINCT salary 
FROM Employee 
ORDER BY salary ASC;
-----------------------------------------------------------------------------------------------------------------------

SELECT Age, MAX(Marks) AS Highest_Marks 
FROM Student 
GROUP BY Age;
-----------------------------------------------------------------------------------------------------------------------

SELECT SUM(Marks) AS Total_Marks 
FROM Student;
