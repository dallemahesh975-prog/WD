-- Create Course table first so it can be referenced if needed, 
-- or simply define them with their respective constraints.
CREATE TABLE Course (
    Course_ID VARCHAR(10) PRIMARY KEY,
    Course_Name VARCHAR(100) NOT NULL,
    Credits INT NOT NULL,
    Dept_ID VARCHAR(10) NOT NULL
);

CREATE TABLE Student (
    Student_ID INT PRIMARY KEY,
    Student_Name VARCHAR(100) NOT NULL,
    Email VARCHAR(100) UNIQUE NOT NULL,
    Age INT CHECK (Age >= 17),
    Dept_ID VARCHAR(10) NOT NULL
);
-- Create a new user
CREATE USER 'college_db'@'localhost' IDENTIFIED BY 'password123';

-- Grant SELECT and INSERT privileges on both tables
GRANT SELECT, INSERT ON Student TO 'college_db'@'localhost';
GRANT SELECT, INSERT ON Course TO 'college_db'@'localhost';

-- Revoke INSERT privilege from the user
REVOKE INSERT ON Student FROM 'college_db'@'localhost';
REVOKE INSERT ON Course FROM 'college_db'@'localhost';

-- Flush privileges to apply changes
FLUSH PRIVILEGES;
-- Create the specified roles
CREATE ROLE 'faculty_role';
CREATE ROLE 'student_role';
-- Grant SELECT privilege along with the ability to grant it to others
GRANT SELECT ON Course TO 'college_db'@'localhost' WITH GRANT OPTION;
-- Start the transaction
START TRANSACTION;

-- INSERT a new record into the course table
INSERT INTO Course (Course_ID, Course_Name, Credits, Dept_ID) 
VALUES ('CS201', 'Data Structures', 4, 'COMP');

-- Create a SAVEPOINT named sp1
SAVEPOINT sp1;

-- DELETE the record just inserted
DELETE FROM Course WHERE Course_ID = 'CS201';

-- ROLLBACK to savepoint sp1 (this undoes the deletion, keeping the insert)
ROLLBACK TO sp1;

-- COMMIT the transaction to permanently save the insertion
COMMIT;

-- Verify the record exists
SELECT * FROM Course WHERE Course_ID = 'CS201';
-- Start transaction
START TRANSACTION;

-- Update emails of two specific students
UPDATE Student 
SET Email = 'new_email1@example.com' 
WHERE Student_ID = 101;

UPDATE Student 
SET Email = 'new_email2@example.com' 
WHERE Student_ID = 102;

-- COMMIT the changes
COMMIT;

-- Verify the updates
SELECT Student_ID, Student_Name, Email FROM Student WHERE Student_ID IN (101, 102);
-- Revoke the role from a user (assuming it was granted to 'college_db')
REVOKE 'faculty_role' FROM 'college_db'@'localhost';

-- Drop the role completely
DROP ROLE 'faculty_role';

-- Verify privileges/roles for the user are removed
SHOW GRANTS FOR 'college_db'@'localhost';
