SELECT 
    c.customer_name, 
    p.Product_name, 
    o.quantity
FROM 
    Customer c
INNER JOIN 
    `Order` o ON c.customer_id = o.customer_id
INNER JOIN 
    Product p ON o.Product_id = p.Product_id;
SELECT 
    c.customer_id,
    c.customer_name, 
    c.city,
    o.Order_id,
    o.quantity
FROM 
    Customer c
LEFT JOIN 
    `Order` o ON c.customer_id = o.customer_id;
SELECT 
    p.Product_id,
    p.Product_name,
    p.Price,
    o.Order_id,
    o.quantity
FROM 
    `Order` o
RIGHT JOIN 
    Product p ON o.Product_id = p.Product_id;
  SELECT 
    c.customer_id,
    c.customer_name,
    p.Product_id,
    p.Product_name
FROM 
    Customer c
CROSS JOIN 
    Product p;
    
    
    
