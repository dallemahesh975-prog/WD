<html>
<head>
<title>Form</title>
</head>

<body>
<form method="POST" action="">
Enter name:
<input type="text" name="name"><br><br>

Enter your age:
<input type="number" name="age"><br><br><br>

<input type="submit" value="submit">
</form>

<?php
if ($_SERVER["REQUEST_METHOD"] == "POST") {

    $name = $_POST['name'];
    $age = $_POST['age'];

    echo "Name: " . $name . "<br>";
    echo "Age: " . $age;
}
?>

</body>
</html>
