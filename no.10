<!DOCTYPE html>
<html>
<head>
    <title>PHP POST Form</title>
</head>
<body>

<form method="POST" action="">
    <label><b>1.</b> Name: </label>
    <input type="text" name="name" required placeholder="Ganesh"><br><br>

    <label><b>2.</b> Age: </label>
    <input type="number" name="age" required placeholder="20"><br><br>

    <label><b>3.</b> Gender: </label>
    <input type="text" name="gender" required placeholder="Male"><br><br>

    <input type="submit" value="Submit">
</form>

<?php
if ($_SERVER["REQUEST_METHOD"] == "POST") {
    $name = $_POST['name'];
    $age = $_POST['age'];
    $gender = $_POST['gender'];

    echo "<br><b>Form POST Output using PHP:</b><br><br>";
    echo "1. Name: " . $name . "<br>";
    echo "2. Age: " . $age . "<br>";
    echo "3. Gender: " . $gender . "<br>";
}
?>

</body>
</html>
