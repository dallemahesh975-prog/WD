SELECT DISTINCT c.customer_id, c.customer_name, c.city
FROM Customer c
JOIN `Order` ord ON c.customer_id = ord.customer_id;
SELECT customer_id, customer_name, city
FROM Customer
WHERE customer_id NOT IN (SELECT DISTINCT customer_id FROM `Order`);
SELECT Product_id, Product_name, Price
FROM Product
WHERE Price = (SELECT MAX(Price) FROM Product);
SELECT 
    ord.Order_id, 
    c.customer_name, 
    p.Product_name, 
    ord.quantity AS quantity_ordered, 
    (ord.quantity * p.Price) AS total_amount
FROM `Order` ord
JOIN Customer c ON ord.customer_id = c.customer_id
JOIN Product p ON ord.Product_id = p.Product_id;
