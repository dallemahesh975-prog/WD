------------------------------------------------------------------------------------------------------------------------
RENAME TABLE Course TO Branch;

--------------------------------------------------------------------------------------------------------------------------
ALTER TABLE Student
ADD CONSTRAINT chk_age CHECK (Age >= 18);

----------------------------------------------------------------------------------------------------------------------
