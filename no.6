<!doctype html>
<html>
  <head>
    <title>Weekly Schedule</title>
  </head>
  <body style="display: flex; justify-content: center; margin: 40px">
    <table
      style="border-collapse: collapse; width: 60%; border: 2px solid #c0603a"
    >
      <thead>
        <tr>
          <th
            colspan="3"
            style="
              background-color: #e2581a;
              color: white;
              font-size: 22px;
              padding: 16px;
              text-align: center;
              border-bottom: 3px solid white;
            "
          >
            Weekly Schedule
          </th>
        </tr>
        <tr>
          <th
            style="
              background-color: #e2581a;
              color: white;
              padding: 12px 20px;
              text-align: center;
              border: 1px solid #c0603a;
            "
          >
            Day
          </th>

          <th
            style="
              background-color: #e2581a;
              color: white;
              padding: 12px 20px;
              text-align: center;
              border: 1px solid #c0603a;
            "
          >
            Task
          </th>

          <th
            style="
              background-color: #e2581a;
              color: white;
              padding: 12px 20px;
              text-align: center;
              border: 1px solid #c0603a;
            "
          >
            Time
          </th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td
            style="
              padding: 14px 20px;
              text-align: center;
              background-color: #fdf3e3;
              border: 1px solid #c0603a;
            "
          >
            Monday
          </td>
          <td
            style="
              padding: 14px 20px;
              text-align: center;
              background-color: #fdf3e3;
              border: 1px solid #c0603a;
            "
          >
            Code Practice
          </td>
          <td
            style="
              padding: 14px 20px;
              text-align: center;
              background-color: #fdf3e3;
              border: 1px solid #c0603a;
            "
          >
            10:00 AM
          </td>
        </tr>
        <tr>
          <td
            style="
              padding: 14px 20px;
              text-align: center;
              background-color: #fdf3e3;
              border: 1px solid #c0603a;
            "
          >
            Wednesday
          </td>
          <td
            style="
              padding: 14px 20px;
              text-align: center;
              background-color: #fdf3e3;
              border: 1px solid #c0603a;
            "
          >
            Team Meeting
          </td>
          <td
            style="
              padding: 14px 20px;
              text-align: center;
              background-color: #fdf3e3;
              border: 1px solid #c0603a;
            "
          >
            2:00 PM
          </td>
        </tr>
        <tr>
          <td
            style="
              padding: 14px 20px;
              text-align: center;
              background-color: #fdf3e3;
              border: 1px solid #c0603a;
            "
          >
            Friday
          </td>
          <td
            style="
              padding: 14px 20px;
              text-align: center;
              background-color: #fdf3e3;
              border: 1px solid #c0603a;
            "
          >
            Project Review
          </td>
          <td
            style="
              padding: 14px 20px;
              text-align: center;
              background-color: #fdf3e3;
              border: 1px solid #c0603a;
            "
          >
            4:00 PM
          </td>
        </tr>
      </tbody>
    </table>
  </body>
</html>
